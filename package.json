{
  "name": "vantare-overlays",
  "version": "1.0.0",
  "private": true,
  "description": "Professional simracing overlays - iRacing, LMU, AC",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.1.0",
  "scripts": {
    "dev": "turbo dev",
    "dev:desktop": "turbo dev --filter=@vantare/desktop",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "test:e2e": "turbo test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,css,md}\"",
    "clean": "turbo clean && rm -rf node_modules",
    "typecheck": "turbo typecheck",
    "changeset": "changeset",
    "release": "turbo build && changeset publish"
  },
  "devDependencies": {
    "prettier": "^3.4.0",
    "turbo": "^2.5.0",
    "typescript": "^5.7.0",
    "@changesets/cli": "^2.27.0"
  }
}
