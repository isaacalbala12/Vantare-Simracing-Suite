{
  "name": "@vantare/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Vantare Overlays - Electron desktop app",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint src/ --ext .ts,.tsx",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "package": "electron-builder build --win",
    "package:all": "electron-builder build --win --x64",
    "release": "electron-builder build --win --publish always",
    "clean": "rm -rf dist out release",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@shared/types": "workspace:*",
    "@vantare/auth": "workspace:*",
    "@vantare/sim-core": "workspace:*",
    "@vantare/types": "workspace:*",
    "@vantare/ui-core": "workspace:*",
    "dotenv": "^17.4.2",
    "electron-log": "^5.2.0",
    "electron-safe-storage": "^1.0.6",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.3.0",
    "koffi": "^3.0.2",
    "machine-id": "^1.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "zod": "^3.23.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "postcss": "^8.4.0",
    "storybook": "^8.6.18",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^1.0.0",
    "vite-plugin-electron-renderer": "^0.14.0",
    "vitest": "^2.1.0"
  }
}
