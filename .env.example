# Supabase — copy to `.env` and fill with values from https://supabase.com/dashboard
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Service role key — Electron MAIN PROCESS and Supabase Edge Functions ONLY.
# Never bundle this in the renderer or commit a real value.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
