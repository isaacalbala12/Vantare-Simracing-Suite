{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Vantare tester changelog fragment",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "issue", "type", "summary", "technicalNotes", "testing", "knownLimitations"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "issue": { "type": "string", "pattern": "^ISA-[0-9]+$" },
    "type": { "enum": ["feature", "fix", "change", "security"] },
    "summary": { "type": "string", "minLength": 1 },
    "technicalNotes": { "$ref": "#/$defs/nonEmptyStrings" },
    "testing": { "$ref": "#/$defs/nonEmptyStrings" },
    "knownLimitations": { "$ref": "#/$defs/nonEmptyStrings" }
  },
  "$defs": {
    "nonEmptyStrings": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
