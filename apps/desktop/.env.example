# Desktop app environment (copy to `.env` in this folder for local dev)
# Values are also read from the monorepo root `.env` when present.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Main process only — used for license admin tasks and local edge-function testing.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
