{
  "id": "dark",
  "name": "Dark",
  "description": "Default dark theme for Vantare Overlays",
  "author": "Vantare",
  "version": "1.0.0",
  "tokens": {
    "color": {
      "surface": "#0a0a0a",
      "surfaceAlt": "#1a1a1a",
      "surfaceElevated": "#2a2a2a",
      "border": "rgba(255,255,255,0.1)",
      "borderSubtle": "rgba(255,255,255,0.05)",
      "primary": "#3b82f6",
      "primaryHover": "#4b92f7",
      "primaryMuted": "#3b82f633",
      "secondary": "#6366f1",
      "secondaryHover": "#7577f5",
      "text": "#ffffff",
      "textMuted": "#666666",
      "textInverse": "#0a0a0a",
      "positive": "#22c55e",
      "negative": "#ef4444",
      "warning": "#eab308",
      "danger": "#ef4444",
      "glass": "rgba(255,255,255,0.06)",
      "glassBorder": "rgba(255,255,255,0.1)",
      "overlay": "#00000080"
    },
    "font": {
      "heading": "'Inter', sans-serif",
      "body": "'Inter', sans-serif",
      "mono": "'JetBrains Mono', monospace",
      "size": {
        "xs": "0.75rem",
        "sm": "0.875rem",
        "base": "1rem",
        "lg": "1.25rem",
        "xl": "1.5rem",
        "2xl": "2rem"
      },
      "weight": {
        "normal": 400,
        "medium": 500,
        "semibold": 600,
        "bold": 700
      }
    },
    "spacing": {
      "xs": "0.25rem",
      "sm": "0.5rem",
      "md": "1rem",
      "lg": "1.5rem",
      "xl": "2rem",
      "2xl": "3rem"
    },
    "radius": {
      "sm": "0.375rem",
      "md": "0.5rem",
      "lg": "0.75rem",
      "xl": "1rem",
      "full": "9999px"
    },
    "shadow": {
      "sm": "0 1px 2px rgba(0,0,0,0.4)",
      "md": "0 4px 12px rgba(0,0,0,0.6)",
      "lg": "0 8px 32px rgba(0,0,0,0.8)",
      "glow": "0 0 20px #3b82f640"
    },
    "animation": {
      "duration": {
        "fast": "150ms",
        "normal": "300ms",
        "slow": "500ms",
        "slowest": "800ms"
      },
      "easing": {
        "default": "cubic-bezier(0.4, 0, 0.2, 1)",
        "bounce": "cubic-bezier(0.34, 1.56, 0.64, 1)",
        "sharp": "cubic-bezier(0.4, 0, 0.6, 1)"
      }
    },
    "glass": {
      "blur": "12px",
      "opacity": 0.6,
      "saturation": "180%"
    },
    "z": {
      "base": 1,
      "overlay": 10,
      "dropdown": 20,
      "modal": 50,
      "toast": 100,
      "tooltip": 200
    }
  },
  "overlayOverrides": {
    "standings": {
      "color": {
        "surface": "rgba(10,10,10,0.8)"
      }
    }
  }
}
